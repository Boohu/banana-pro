{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "筋斗云AI",
  "version": "2.7.4",
  "identifier": "com.dztool.banana",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1440,
        "height": 900,
        "transparent": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$HOME/**"
        ]
      },
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
      "active": true,
      "targets": "all",
      "createUpdaterArtifacts": true,
      "macOS": {
        "entitlements": "Entitlements.plist"
      },
      "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/server"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgwMzEzQjQ1RDJDOThGNkQKUldSdGo4blNSVHN4Z09KMEdneXFrRDEvc3F3WlVzaVIzVUpkbkVYcmhpREcxcTI5dUdBSTU4eXcK",
      "endpoints": [
        "https://auth.3ux.cn/api/update/check?target={{target}}&arch={{arch}}&current_version={{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
